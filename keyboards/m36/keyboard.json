{
    "keyboard_name": "SZR36",
    "maintainer": "SZRKBD",
    "manufacturer": "SZRKBD",
    "bootloader": "stm32-dfu",
    "url": "https://github.com/foostan/crkbd",
    "usb": {
        "pid": "0x45D4",
        "vid": "0x3601",
        "device_version": "0.0.1"
    },
    "processor": "STM32F401",
    "features": {
        "bootmagic": true,
        "extrakey": true,
        "nkro": true,
        "oled": false,
        "rgblight": false,
        "rgb_matrix": true,
        "mousekey": true,
        "encoder": false
    },

    "diode_direction": "COL2ROW",
    "matrix_pins": {
        "direct":[
            ["B4", "B0", "B1", "B12", "B13"],
            ["B5", "C5", "B2", "B14",  "B15"],
            ["B3", "C4", "B10", "C9",  "C11"],
            ["NO_PIN", "NO_PIN", "A1", "C14",  "C12"]

        ]
    },
    "split": {
        "enabled": true,
        "matrix_pins": {
            "right": {
                "direct": [
                    ["B2", "B10",  "C10",  "C11", "B6"],
                    ["B0", "B1",  "C12",  "D2", "B7"],
                    ["C5", "B12",   "B3", "B4", "B5"],
                    ["C4", "A1",  "C13",   "NO_PIN", "NO_PIN"]
                ]
            }
        }
         },
    "layouts": {
